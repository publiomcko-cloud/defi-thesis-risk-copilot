APP_ENV=development
APP_NAME=DeFi Thesis & Risk Copilot
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5435/defi_copilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=defi_copilot
POSTGRES_HOST_PORT=5435
LLM_SYNTHESIS_ENABLED=false
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=8
DEFILLAMA_BASE_URL=https://api.llama.fi
RAG_SEMANTIC_ENABLED=false
RAG_EMBEDDING_PROVIDER=local_semantic
RAG_HYBRID_KEYWORD_WEIGHT=0.45
RAG_HYBRID_VECTOR_WEIGHT=0.45
RAG_HYBRID_METADATA_WEIGHT=0.10
AUTH_ENABLED=false
ADMIN_EMAIL=admin@example.local
ADMIN_BOOTSTRAP_TOKEN=
ADMIN_PASSWORD=
AUTH_SECRET_KEY=
CREDENTIAL_ENCRYPTION_KEY=
