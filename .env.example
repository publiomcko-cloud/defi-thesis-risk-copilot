APP_ENV=development
APP_NAME=DeFi Thesis & Risk Copilot
PUBLIC_DEMO_MODE=false
APP_VERSION=1.0.0
DEPLOYMENT_COMMIT=
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_PUBLIC_DEMO_MODE=false
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5435/defi_copilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=defi_copilot
POSTGRES_HOST_PORT=5435
LLM_SYNTHESIS_ENABLED=false
LLM_PROVIDER=disabled
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=8
DEFILLAMA_BASE_URL=https://api.llama.fi
RAG_SEMANTIC_ENABLED=false
RAG_EMBEDDING_PROVIDER=local_semantic
RAG_HYBRID_KEYWORD_WEIGHT=0.45
RAG_HYBRID_VECTOR_WEIGHT=0.45
RAG_HYBRID_METADATA_WEIGHT=0.10
AUTH_ENABLED=false
ADMIN_EMAIL=admin@example.local
ADMIN_BOOTSTRAP_TOKEN=
ADMIN_PASSWORD=
AUTH_SECRET_KEY=
CREDENTIAL_ENCRYPTION_KEY=
VAST_ENABLED=false
VAST_API_BASE_URL=https://console.vast.ai/api/v0
VAST_API_KEY=
VAST_CREDENTIAL_NAME=vast_ai_default
VAST_MAX_HOURLY_COST_USD=0.50
VAST_MAX_SESSION_MINUTES=30
VAST_MAX_ACTIVE_INSTANCES=1
VAST_GPU_ALLOWLIST=RTX_4090,RTX_3090,A5000,A6000
VAST_MIN_GPU_RAM_GB=16
VAST_DISK_GB=40
VAST_REQUIRE_VERIFIED=true
VAST_AUTO_DESTROY=true
VAST_IDLE_TIMEOUT_SECONDS=300
VAST_IMAGE=
VAST_MODEL=
VAST_CONTAINER_PORT=8000
VAST_STARTUP_TIMEOUT_SECONDS=600
VAST_POLL_INTERVAL_SECONDS=10
VAST_DRY_RUN=true
